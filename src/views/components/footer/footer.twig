{#
| Variable                          | Type                      | Description                                                     |
|-----------------------------------|---------------------------|-----------------------------------------------------------------|
| store                             | Store                     |                                                                 |
| store.logo                        | string                    |                                                                 |
| store.name                        | string                    |                                                                 |
| store.url                         | string                    |                                                                 |
| store.slogan                      | ?string                   |                                                                 |
| menu                              | object                    |                                                                 |
| menu.footer                       | Menu[]                    |                                                                 |
#}
<footer class="bg-white pt-32 pb-12 px-6 lg:px-24 border-t border-black/5">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-20 mb-32">
        <div class="flex flex-col items-start">
            <div class="flex flex-col items-center mb-10">
                {% if store.logo %}
                    <img src="{{ store.logo }}" alt="{{ store.name }}" style="max-height: 50px;" class="w-auto object-contain">
                {% else %}
                    <h2 class="text-3xl font-bold tracking-[0.2em] primary-text serif-heading leading-none">{{ store.name }}</h2>
                {% endif %}
            </div>
            <p class="text-text-muted text-sm leading-relaxed mb-10 serif-heading italic">
                {{ store.description ?: 'المقصد الأول في المملكة العربية السعودية للباحثين عن أرقى منتجات العناية بالبشرة والجمال الفلسفي.' }}
            </p>
            <div class="flex gap-8">
                {% if store.social.instagram %}
                    <a class="text-text-muted hover:text-primary transition-all" href="{{ store.social.instagram }}"><span class="material-symbols-outlined text-xl">public</span></a>
                {% endif %}
                {% if store.social.twitter %}
                    <a class="text-text-muted hover:text-primary transition-all" href="{{ store.social.twitter }}"><span class="material-symbols-outlined text-xl">share</span></a>
                {% endif %}
                {% if store.contacts.email %}
                    <a class="text-text-muted hover:text-primary transition-all" href="mailto:{{ store.contacts.email }}"><span class="material-symbols-outlined text-xl">alternate_email</span></a>
                {% endif %}
            </div>
        </div>
        
        {% for menu in menu.footer %}
            <div>
                <h6 class="text-xs font-bold uppercase tracking-[0.2em] primary-text mb-10">{{ menu.name }}</h6>
                <ul class="space-y-6">
                    {% for item in menu.items %}
                        <li><a class="text-text-muted text-sm hover:text-primary transition-all" href="{{ item.url }}">{{ item.name }}</a></li>
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}

        <div>
            <h6 class="text-xs font-bold uppercase tracking-[0.2em] primary-text mb-10">{{ trans('common.help') }}</h6>
            <ul class="space-y-6">
                {% if store.social.whatsapp %}
                    <li><a class="text-text-muted text-sm hover:text-primary transition-all" href="{{ store.social.whatsapp }}">{{ trans('common.whatsapp') }}</a></li>
                {% endif %}
                <li><a class="text-text-muted text-sm hover:text-primary transition-all" href="{{ link('pages.index') }}">{{ trans('common.pages') }}</a></li>
            </ul>
        </div>
    </div>
    <div class="text-center border-t border-black/5 pt-12">
        <p class="text-[10px] text-text-muted uppercase tracking-widest font-bold">&copy; {{ "now"|date("Y") }} {{ store.name }}. All Rights Reserved.</p>
    </div>
</footer>
