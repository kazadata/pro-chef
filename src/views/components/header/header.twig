{#
| Variable                          | Type                      | Description                                                     |
|-----------------------------------|---------------------------|-----------------------------------------------------------------|
| store                             | Store                     |                                                                 |
| store.logo                        | string                    |                                                                 |
| store.name                        | string                    |                                                                 |
| store.url                         | string                    |                                                                 |
| store.slogan                      | ?string                   |                                                                 |
| user                              | User                      |                                                                 |
| user.is_authenticated             | bool                      |                                                                 |
| user.first_name                   | string                    |                                                                 |
| menu                              | object                    |                                                                 |
| menu.main                         | Menu[]                    |                                                                 |
| theme                             | Theme                     |                                                                 |
| theme.settings.header_is_sticky   | bool                      |                                                                 |
#}
<nav class="sticky top-0 z-50 glass-nav border-b border-black/5">
    <div class="px-6 lg:px-24 py-6 flex flex-col gap-6">
        <div class="flex items-center justify-between">
            <button class="hidden lg:flex items-center gap-2 text-text-muted hover:text-primary transition-colors" onclick="salla.event.dispatch('search::open')">
                <span class="material-symbols-outlined text-2xl">search</span>
                <span class="text-xs uppercase tracking-widest">{{ trans('common.search') }}</span>
            </button>
            <div class="flex flex-col items-center">
                <a href="{{ store.url }}">
                    {% if store.logo %}
                        <img src="{{ store.logo }}" alt="{{ store.name }}" style="max-height: 50px;" class="w-auto object-contain">
                    {% else %}
                        <h1 class="text-3xl lg:text-4xl font-bold tracking-[0.2em] primary-text serif-heading leading-none">{{ store.name }}</h1>
                    {% endif %}
                </a>
                <span class="text-[9px] uppercase tracking-[0.4em] mt-1 text-accent font-bold">{{ store.slogan ?: 'The Art of Care' }}</span>
            </div>
            <div class="flex items-center gap-8">
                {% if user.is_authenticated %}
                    <a class="hidden md:flex flex-col items-center group" href="{{ link('customer.home') }}">
                        <span class="text-[10px] text-accent tracking-widest font-bold">{{ trans('common.welcome') }} {{ user.first_name }}</span>
                        <span class="text-xs font-medium primary-text group-hover:text-accent transition-colors">{{ trans('common.profile') }}</span>
                    </a>
                {% else %}
                    <button class="hidden md:flex flex-col items-center group" onclick="salla.event.dispatch('login::open')">
                        <span class="text-[10px] text-accent tracking-widest font-bold">{{ trans('common.welcome') }}</span>
                        <span class="text-xs font-medium primary-text group-hover:text-accent transition-colors">{{ trans('common.login') }}</span>
                    </button>
                {% endif %}
                <div class="flex gap-6 items-center">
                    <a href="{{ link('wishlist.index') }}" class="relative group">
                        <span class="material-symbols-outlined text-2xl font-light group-hover:text-primary transition-colors">favorite</span>
                        {% if wishlist_count %}
                            <span class="absolute -top-1 -right-2 bg-accent text-white text-[8px] px-1.5 py-0.5 rounded-full">{{ wishlist_count }}</span>
                        {% endif %}
                    </a>
                    <button class="relative group" onclick="salla.cart.open()">
                        <span class="material-symbols-outlined text-2xl font-light group-hover:text-primary transition-colors">shopping_bag</span>
                        <span class="absolute -top-1 -right-2 primary-bg text-white text-[8px] px-1.5 py-0.5 rounded-full cart-badge">{{ cart.items_count }}</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="hidden lg:flex items-center gap-12 justify-center border-t border-black/5 pt-4">
            {% for item in menu.main %}
                <a class="text-xs {{ item.is_current ? 'font-bold primary-text relative after:absolute after:bottom-[-4px] after:right-0 after:w-full after:h-[1px] after:bg-accent' : 'font-medium text-text-muted hover:text-primary transition-colors' }} tracking-[0.2em]" href="{{ item.url }}">{{ item.name }}</a>
            {% endfor %}
        </div>
    </div>
</nav>
