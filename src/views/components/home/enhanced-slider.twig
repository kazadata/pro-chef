{#
| Variable                       | Type     | Description                                                                  |
|--------------------------------|----------|------------------------------------------------------------------------------|
| component                      | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.slides[].image       | string   | Image url                                                                    |
| component.slides[].title       | ?string  |                                                                              |
| component.slides[].description | ?string  |                                                                              |
| component.slides               | object[] | list of slides                                                               |
| position                       | int      | Sorting number start from zero                                               |
#}
<section class="s-block s-block--hero-slider s-block--full-bg wide-placeholder editorial-hero"> 
    <salla-slider 
      id="main-slider-{{ position }}"
      auto-play
      static-when-single
      slider-config='{"lazy":"false"}'
      {{ component.slides|length > 1 ? '' : 'show-controls="false"' }}
      type="fullwidth">
        <div slot="items">
            {% for slide in component.slides %}
                <div class="swiper-slide w-full min-h-[420px] lg:min-h-[760px] bg-dark relative">
					<div style="background-image: url({{ slide.image }});" class="{{ slide.without_overlay ? '' : 'overlay-bg' }} bg-cover bg-center absolute inset-0"></div>
                    <div class="container pb-16 sm:pb-0 home-slider__content relative h-full flex items-center">
                        <div class="w-full md:w-8/12 lg:w-6/12 text-white text-right editorial-hero-content">
                            {% if slide.title %}
                              <span class="editorial-hero-kicker">المجموعة المختارة</span>
                            {% endif %}
                            <h2 data-swiper-parallax="-500" class="editorial-hero-title">{{ slide.title }}</h2>
                            <p data-swiper-parallax="-300" class="description editorial-hero-desc">{{ slide.description }}</p>
                            <div class="editorial-hero-actions">
                              <a href="{{ slide.url ?: store.url }}" class="btn btn--primary">تسوق الآن</a>
                              <a href="{{ store.url }}" class="btn btn--outline light">اكتشف المزيد</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </salla-slider>
</section> 
