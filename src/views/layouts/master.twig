{# ############## Shared Variables in all views ################
| Variable                                           | Type     | Description                                                                                              |
|----------------------------------------------------|----------|----------------------------------------------------------------------------------------------------------|
| store                                              | Store    |                                                                                                          |
| store.id                                           | int      |                                                                                                          |
| store.name                                         | string   |                                                                                                          |
| store.username                                     | string   |                                                                                                          |
| store.description                                  | string   |                                                                                                          |
| store.slogan                                       | ?string  | * if feature in twilight.json                                                                            |
| store.logo                                         | string   |                                                                                                          |
| store.url                                          | string   |                                                                                                          |
| store.api                                          | string   | the api url for current store                                                                            |
| store.icon                                         | string   |                                                                                                          |
| store.contacts                                     | object   | [mobile, phone, email, whatsapp, telegram], ex. store.contacts.email                                     |
| store.social                                       | object   | [instagram, snapchat, twitter, youtube, facebook, pinterest, maroof, whatsapp], ex. store.social.twitter |
| theme                                              | Theme    |                                                                                                          |
| theme.settings                                     | object   | dynamic object with values of the `settings` in twilight.json                                            |
#}
<!DOCTYPE html>
<html lang="{{ user.language.code }}" dir="{{ user.language.dir }}">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    {# Fonts and External Styles #}
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&amp;family=Plus+Jakarta+Sans:wght@300;400;500;700&amp;family=Noto+Sans+Arabic:wght@300;400;600;800&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="{{ 'app.css' | asset }}">
    <link rel="stylesheet" href="{{ theme.font.path|cdn }}"/>
    <link rel="stylesheet" href="{{ 'fonts/sallaicons.css'|cdn }}"/>

    {# Alpine.js for interactive elements #}
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

    {# Custom CSS Variables and Global Styles from code.html #}
    <style>
        :root {
            --bg-warm: #FBF8F4;
            --primary: #0F4C8A;
            --accent: #8C7355;
            --text-main: #2D2926;
            --text-muted: #6B6661;
            
            --font-main: 'Noto Sans Arabic', sans-serif;
            --color-primary: #0F4C8A;
            --color-primary-dark: {{ theme.color.darker(0.15) }};
            --color-primary-light: {{ theme.color.lighter(0.15) }};
            --color-primary-reverse: {{ theme.color.reverse_text }};
        }
        body {
            font-family: 'Noto Sans Arabic', sans-serif;
            background-color: var(--bg-warm);
            color: var(--text-main);
            overflow-x: hidden;
        }
        .serif-heading {
            font-family: 'Amiri', serif;
        }
        .glass-nav {
            background: rgba(251, 248, 244, 0.9);
            backdrop-filter: blur(12px);
        }
        .editorial-spacing {
            letter-spacing: 0.05em;
        }
        .grayscale-hover img {
            transition: filter 0.5s ease;
            filter: grayscale(100%);
        }
        .grayscale-hover:hover img {
            filter: grayscale(0%);
        }
        .primary-text { color: var(--primary); }
        .primary-bg { background-color: var(--primary); }
        .primary-border { border-color: var(--primary); }
        
        /* Marquee Animation */
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-marquee {
            display: flex;
            width: max-content;
            animation: marquee 30s linear infinite;
        }
    </style>

    <script data-cfasync="false">
        window.header_is_sticky = "{{theme.settings.get('header_is_sticky', true)}}"
        window.imageZoom = "{{theme.settings.get('imageZoom')}}"
        window.can_access_wallet = {{ user.can_access_wallet | json_encode }}
        window.enable_more_menu = "{{ theme.settings.get('enable_more_menu', true) }}"
        window.enable_add_product_toast = "{{ theme.settings.get('enable_add_product_toast', true) }}"
    </script>
    
    {% hook 'head:start' %}
    {% hook head %}
    {% block styles %}{% endblock %}
    {% hook 'head:end' %}
</head>
<body id="app" class="theme-raed overflow-x-hidden selection:bg-primary/20">
    <noscript>
        To get full functionality of this site you need to enable JavaScript. Here is how
        <a href="https://www.enable-javascript.com/" rel="noreferrer" target="_blank">To enable JavaScript on webpage</a>.
    </noscript>

    <div class="app-inner flex flex-col min-h-full">
        {% hook 'body:start' %}
        
        {# Top Bar from code.html #}
        <div class="bg-white/50 border-b border-black/5 text-[11px] py-2 px-6 lg:px-24 flex justify-between items-center uppercase tracking-widest font-medium">
            <div class="flex gap-6">
                <div class="flex items-center gap-1 cursor-pointer hover:text-primary transition-colors">
                    <span>{{ user.currency.name }}</span>
                    <span class="material-symbols-outlined text-[14px]">expand_more</span>
                </div>
                <div class="flex items-center gap-1 cursor-pointer border-r border-black/10 pr-6">
                    <span>{{ user.language.name }}</span>
                </div>
            </div>
            <div class="flex gap-8 text-text-muted">
                <a class="hover:text-primary transition-colors" href="#">المجلة</a>
                <a class="hover:text-primary transition-colors" href="#">قصتنا</a>
                <a class="hover:text-primary transition-colors" href="#">تواصل</a>
            </div>
        </div>

        {# Header Component #}
        {% component 'header.header' %}

        {# Main Content #}
        <main id="main-content" role="main">
            {% block content %}{% endblock %}
        </main>

        {# Footer Component #}
        {% component 'footer.footer' %}
    </div>

    {% hook 'body:end' %}
    
    {# Toast Notification #}
    {% if theme.settings.get('enable_add_product_toast', true) %}
        <salla-add-product-toast></salla-add-product-toast>
    {% endif %}

    {# Scripts #}
    <script defer crossorigin="anonymous" src="{{ 'app.js' | asset }}"></script>
    <script defer src="{{ 'product-card.js'|asset }}"></script>
    <script defer src="{{ 'main-menu.js'|asset }}"></script>
    {% if theme.settings.get('enable_add_product_toast', true) %}
        <script defer src="{{ 'add-product-toast.js'|asset }}"></script>
    {% endif %}

    {# Twilight Components #}
    <salla-offer-modal></salla-offer-modal>
    <salla-search></salla-search>

    {% if user.type=='guest' %}
        <salla-login-modal></salla-login-modal>
    {% endif %}
    {% if store.scope %}
        <salla-scopes selection="{{ store.scope.display_as == 'popup' ? 'mandatory' : 'optional' }}"></salla-scopes>
    {% endif %}
    
    {% block scripts %}{% endblock %}
</body>
</html>
