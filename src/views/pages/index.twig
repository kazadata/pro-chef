                    <div class="absolute inset-0 flex flex-col items-center justify-center text-white p-8">
                        <h4 class="text-3xl serif-heading mb-4">ترطيب فائق</h4>
                        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.3em] border-b border-white/30 pb-1 hover:border-white transition-all">استكشاف المنتجات</a>
                    </div>
                </div>
                <div class="relative group overflow-hidden aspect-[4/5] bg-black">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBd5Hsec6yJVFrAMlZazPMhjHx817qATJdHQD8eeZpKUIXOHuSmFqxAeKAXMUuIcvKG3EfrKjO4eoj9I5x02lgSJJqSm2pIBnKviBXnPRkjFIYFXF8YKY9EN2CCvoWdBeRjv7FYfvfhSM7IWMqmZQqw8gQMj1RCc5WKVg4r84LSWXcMHqDDR0pJgOqO9_rKw-k0IBOeEfxLMTcNXeBzYv7LD4TaZbPAl-91LEBbbXjWq6oSIvlsE7SLo5KafY3O89doZ3SggkVJZhk" alt="Brightening" class="w-full h-full object-cover opacity-70 group-hover:scale-110 transition-transform duration-1000 grayscale group-hover:grayscale-0">
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-white p-8">
                        <h4 class="text-3xl serif-heading mb-4">تفتيح ونضارة</h4>
                        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.3em] border-b border-white/30 pb-1 hover:border-white transition-all">استكشاف المنتجات</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. Curated Bundles (Kits) -->
    <section class="py-32 px-6 lg:px-24 bg-[#FBF8F4]">
        <div class="max-w-7xl mx-auto">
            <div class="flex justify-between items-end mb-16">
                <div class="text-right">
