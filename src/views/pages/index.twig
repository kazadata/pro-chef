{% extends "layouts.master" %}

{% block content %}
    <!-- 1. Skin Routine Finder (Interactive Quiz) -->
    <section class="py-32 px-6 lg:px-24 bg-white" x-data="{ 
        step: 1, 
        type: '',
        recommendations: {
            'oily': { title: 'مجموعة التوازن المطفي', desc: 'تركيبة خفيفة تتحكم في اللمعان وتشد المسام.' },
            'dry': { title: 'مجموعة الترطيب العميق', desc: 'عناية غنية بالسيراميد لترميم حاجز البشرة.' },
            'sensitive': { title: 'مجموعة النقاء المهدئة', desc: 'مكونات طبيعية مهدئة تخفف من حدة التهيج.' },
            'combination': { title: 'مجموعة العناية المزدوجة', desc: 'توازن مثالي للمناطق الدهنية والجافة.' }
        }
    }">
        <div class="max-w-4xl mx-auto text-center">
            <div x-show="step === 1" x-transition>
                <span class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block">مستشارك الخاص</span>
                <h3 class="text-4xl lg:text-5xl serif-heading mb-12">ما هو نوع بشرتكِ؟</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <button @click="type = 'oily'; step = 2" class="border border-black/5 p-8 hover:border-primary hover:bg-primary/5 transition-all aspect-square flex flex-col items-center justify-center gap-4">
                        <span class="material-symbols-outlined text-3xl font-light">water_drop</span>
                        <span class="text-xs font-bold tracking-widest uppercase">دهنية</span>
                    </button>
                    <button @click="type = 'dry'; step = 2" class="border border-black/5 p-8 hover:border-primary hover:bg-primary/5 transition-all aspect-square flex flex-col items-center justify-center gap-4">
                        <span class="material-symbols-outlined text-3xl font-light">wb_sunny</span>
                        <span class="text-xs font-bold tracking-widest uppercase">جافة</span>
                    </button>
                    <button @click="type = 'sensitive'; step = 2" class="border border-black/5 p-8 hover:border-primary hover:bg-primary/5 transition-all aspect-square flex flex-col items-center justify-center gap-4">
                        <span class="material-symbols-outlined text-3xl font-light">spa</span>
                        <span class="text-xs font-bold tracking-widest uppercase">حساسة</span>
                    </button>
                    <button @click="type = 'combination'; step = 2" class="border border-black/5 p-8 hover:border-primary hover:bg-primary/5 transition-all aspect-square flex flex-col items-center justify-center gap-4">
                        <span class="material-symbols-outlined text-3xl font-light">contrast</span>
                        <span class="text-xs font-bold tracking-widest uppercase">مختلطة</span>
                    </button>
                </div>
            </div>
            <div class="bg-[#F7F7F7] p-12 lg:p-20" x-show="step === 2" x-transition>
                <h4 class="text-2xl serif-heading mb-4">روتينكِ المقترح</h4>
                <div class="w-12 h-px bg-accent mx-auto mb-8"></div>
                <h5 class="text-3xl primary-text serif-heading mb-4" x-text="recommendations[type]?.title"></h5>
                <p class="text-text-muted mb-10 max-w-sm mx-auto italic" x-text="recommendations[type]?.desc"></p>
                <div class="flex gap-4 justify-center">
                    <button class="primary-bg text-white px-10 py-4 text-[10px] font-bold uppercase tracking-widest">عرض المجموعة</button>
                    <button @click="step = 1" class="border border-black/10 px-10 py-4 text-[10px] font-bold uppercase tracking-widest">إعادة الاختبار</button>
                </div>
            </div>
        </div>
    </section>

    <!-- 2. Shop by Concern -->
